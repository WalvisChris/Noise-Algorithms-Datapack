function func:noise/random2:
    function func:plane/refill
    execute as @e[tag=dummy] store result score @s binary run scoreboard players get @e[tag=r2,limit=1,sort=random] random2
    execute as @e[tag=dummy] at @s run function func:utils/render2

function func:noise/random5:
    function func:plane/refill
    execute as @e[tag=dummy] store result score @s random5 run scoreboard players get @e[tag=r5,limit=1,sort=random] random5
    execute as @e[tag=dummy] at @s run function func:utils/render5

function func:noise/random10:
    function func:plane/refill
    execute as @e[tag=dummy] store result score @s random10 run scoreboard players get @e[tag=r10,limit=1,sort=random] random10
    execute as @e[tag=dummy] at @s run function func:utils/render10

function func:noise/lerp10:
    function func:plane/clear

    # create 5x5 grid
    for x in range (5):
        for z in range (5):
            x_pos = x*5
            z_pos = z*5
            summon armor_stand x_pos -63 z_pos {NoGravity:1,Tags:["grid","dummy"],Small:1,Invisible:1}

    # assign random values to grid
    execute as @e[tag=grid] store result score @s random10 run scoreboard players get @e[tag=r10,limit=1,sort=random] random10
    execute as @e[tag=grid] at @s run function func:utils/render10

    # summon lerper
    summon armor_stand 0 -63 0 {NoGravity:1,Tags:["lerp","dummy"],Small:0,Invisible:1}

    # horizontal lerp
    for x in range(5):
        x_pos = x*5
        tp @e[tag=lerp] x_pos -63 0

        for z in range(4):
            # set start and end
            execute as @e[tag=lerp] at @s run tag @e[tag=grid,limit=1,sort=nearest] add start
            execute as @e[tag=lerp] at @s positioned ~ ~ ~5 run tag @e[tag=grid,limit=1,sort=nearest] add end

            # get start * 100
            execute as @e[tag=lerp] store result score @s start run scoreboard players get @e[tag=start,limit=1] random10
            scoreboard players operation @e[tag=lerp] start *= 100 const

            # get end * 100
            execute as @e[tag=lerp] store result score @s end run scoreboard players get @e[tag=end,limit=1] random10
            scoreboard players operation @e[tag=lerp] end *= 100 const

            # subtract
            scoreboard players operation @e[tag=lerp] end -= @e[tag=lerp] start

            # divide by 4
            scoreboard players operation @e[tag=lerp] end /= 4 const

            # take 4 steps
            for i in range(4):
                execute as @e[tag=lerp] at @s run tp @s ~ ~ ~1
                scoreboard players operation @e[tag=lerp] start += @e[tag=lerp] end
                execute at @e[tag=lerp] run summon armor_stand ~ ~ ~ {NoGravity:1,Tags:["grid","dummy","new"],Small:1,Invisible:1}
                execute as @e[tag=lerp] run scoreboard players operation @e[tag=new] random10 = @s start
                execute as @e[tag=new] run function func:utils/round100
                tag @e[tag=new] remove new
            
            tag @e[tag=start] remove start
            tag @e[tag=end] remove end
            execute as @e[tag=lerp] at @s run tp @s ~ ~ ~1

    # render
    execute as @e[tag=grid] at @s run function func:utils/render10
    tp @e[tag=lerp] 0 -63 0

    # vertical lerp
    for z in range(21):
        tp @e[tag=lerp] 0 -63 z

        for x in range(4):

            # set start and end
            execute as @e[tag=lerp] at @s run tag @e[tag=grid,limit=1,sort=nearest] add start
            execute as @e[tag=lerp] at @s positioned ~5 ~ ~ run tag @e[tag=grid,limit=1,sort=nearest] add end

            # get start * 100
            execute as @e[tag=lerp] store result score @s start run scoreboard players get @e[tag=start,limit=1] random10
            scoreboard players operation @e[tag=lerp] start *= 100 const

            # get end * 100
            execute as @e[tag=lerp] store result score @s end run scoreboard players get @e[tag=end,limit=1] random10
            scoreboard players operation @e[tag=lerp] end *= 100 const

            # subtract
            scoreboard players operation @e[tag=lerp] end -= @e[tag=lerp] start

            # divide by 4
            scoreboard players operation @e[tag=lerp] end /= 4 const

            # take 4 steps
            for i in range(4):
                execute as @e[tag=lerp] at @s run tp @s ~1 ~ ~
                scoreboard players operation @e[tag=lerp] start += @e[tag=lerp] end
                execute at @e[tag=lerp] run summon armor_stand ~ ~ ~ {NoGravity:1,Tags:["grid","dummy","new"],Small:1,Invisible:1}
                execute as @e[tag=lerp] run scoreboard players operation @e[tag=new] random10 = @s start
                execute as @e[tag=new] run function func:utils/round100
                tag @e[tag=new] remove new
            
            tag @e[tag=start] remove start
            tag @e[tag=end] remove end
            execute as @e[tag=lerp] at @s run tp @s ~1 ~ ~

    # render
    execute as @e[tag=grid] at @s run function func:utils/render10
    tp @e[tag=lerp] 0 -63 0

function func:noise/average:
    # start
    summon armor_stand 0 -63 0 {NoGravity:1,Tags:["avg"],Small:0,Invisible:0}
    execute as @e[tag=dummy,limit=1,sort=random] at @s run tp @e[tag=avg] ~ ~ ~
    scoreboard players set @e[tag=avg] sum 0
    scoreboard players set @e[tag=avg] count 0

    # check north
    execute as @e[tag=avg] at @s positioned ~ ~ ~-1 if entity @e[tag=dummy,distance=...5]:
        store result score @s temp run scoreboard players get @e[tag=dummy,limit=1,sort=nearest] random10
        scoreboard players operation @s temp *= 100 const
        scoreboard players operation @s sum += @s temp
        scoreboard players add @s count 1

    # check south
    execute as @e[tag=avg] at @s positioned ~ ~ ~1 if entity @e[tag=dummy,distance=...5]:
        store result score @s temp run scoreboard players get @e[tag=dummy,limit=1,sort=nearest] random10
        scoreboard players operation @s temp *= 100 const
        scoreboard players operation @s sum += @s temp
        scoreboard players add @s count 1

    # check east
    execute as @e[tag=avg] at @s positioned ~1 ~ ~ if entity @e[tag=dummy,distance=...5]:
        store result score @s temp run scoreboard players get @e[tag=dummy,limit=1,sort=nearest] random10
        scoreboard players operation @s temp *= 100 const
        scoreboard players operation @s sum += @s temp
        scoreboard players add @s count 1

    # check west
    execute as @e[tag=avg] at @s positioned ~-1 ~ ~ if entity @e[tag=dummy,distance=...5]:
        store result score @s temp run scoreboard players get @e[tag=dummy,limit=1,sort=nearest] random10
        scoreboard players operation @s temp *= 100 const
        scoreboard players operation @s sum += @s temp
        scoreboard players add @s count 1

    # average
    scoreboard players operation @e[tag=avg] sum /= @e[tag=avg] count
    execute as @e[tag=avg] at @s run scoreboard players operation @e[tag=dummy,limit=1,sort=nearest] random10 = @s sum

    # rounding
    execute as @e[scores={random10=11..}] run function func:utils/round100

    # render
    execute as @e[tag=dummy] at @s run function func:utils/render10

    # end
    kill @e[tag=avg]

function func:noise/voronoi:
    # start clean
    function func:plane/clear

    # vul grid met dummy
    function func:plane/refill

    # controle punten
    execute at @e[tag=dummy,limit=12,sort=random] run summon armor_stand ~ ~ ~ {NoGravity:1,Tags:["control"],Small:0,Invisible:1}

    # kill 21x21 dummy
    function func:plane/clear

    # grid
    for x in range(21):
        for z in range(21):
            summon armor_stand x -63 z {NoGravity:1,Tags:["dummy","new"],Small:1,Invisible:1}
            execute as @e[tag=new] at @s run function func:utils/get_distance_to_control
            execute as @e[tag=new] at @s run function func:utils/render10
            tag @e[tag=new] remove new
    
    # end
    kill @e[tag=control]